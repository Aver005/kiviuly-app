# Copy to .env and adjust before deploying:  cp .env.example .env
#
# Secret used to HMAC-sign proof-of-work challenges. MUST be a long random
# string in production (e.g. `openssl rand -hex 32`).
POW_SECRET=change-me-in-production

# PoW difficulty in leading zero bits (8–28). 17 ≈ a few hundred ms in-browser.
# Raise it to make automated abuse more expensive; lower it for snappier UX.
POW_DIFFICULTY=17
